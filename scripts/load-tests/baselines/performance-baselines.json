{
  "version": "1.0.0",
  "description": "Performance baselines for regression detection. Update when intentional improvements are made.",
  "thresholds": {
    "http_req_duration": {
      "p50_ms": 150,
      "p95_ms": 500,
      "p99_ms": 1000
    },
    "http_req_failed": {
      "rate_max": 0.01
    },
    "http_reqs": {
      "min_rps": 200
    }
  },
  "scenarios": {
    "user_journey": {
      "p95_ms": 500,
      "p99_ms": 1000,
      "error_rate_max": 0.05
    },
    "high_concurrency": {
      "p95_ms": 1000,
      "p99_ms": 2000,
      "error_rate_max": 0.05
    },
    "stress": {
      "p95_ms": 2000,
      "p99_ms": 5000,
      "error_rate_max": 0.2
    },
    "spike": {
      "p95_ms": 3000,
      "error_rate_max": 0.15
    },
    "soak": {
      "p95_ms": 600,
      "p99_ms": 1200,
      "error_rate_max": 0.01
    }
  }
}
